generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String?
  avatarUrl         String?
  role              String    @default("user")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  subscription      Subscription?
  routes            Route[]
  rideScoreHistory  RideScoreHistory[]
  preferences       UserPreferences?
  deviceIntegrations DeviceIntegration[]
  passwordResetTokens PasswordResetToken[]
  pushSubscriptions PushSubscription[]
  groupRidesCreated GroupRide[] @relation("GroupRideCreator")
  groupRideRsvps    GroupRideParticipant[]
  liveSessions      LiveSession[]
  emergencyContacts EmergencyContact[]
  roadClosures      RoadClosure[]
  rides             Ride[]

  @@map("users")
}

model GroupRide {
  id            String    @id @default(cuid())
  creatorId     String
  creator       User      @relation("GroupRideCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  sport         String    @default("cycling")
  startTime     DateTime
  lat           Float
  lng           Float
  locationName  String
  pace          String?
  distanceMi    Float?
  maxRiders     Int?
  visibility    String    @default("public")   // public | unlisted
  inviteCode    String    @unique @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants  GroupRideParticipant[]

  @@index([startTime])
  @@index([sport, startTime])
  @@map("group_rides")
}

model GroupRideParticipant {
  id           String     @id @default(cuid())
  groupRideId  String
  groupRide    GroupRide  @relation(fields: [groupRideId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  status       String     @default("going")   // going | maybe
  joinedAt     DateTime   @default(now())

  @@unique([groupRideId, userId])
  @@index([userId])
  @@map("group_ride_participants")
}

model PushSubscription {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint     String    @unique
  p256dh       String
  authKey      String
  userAgent    String?

  // Location to monitor for storms (set when the user enables alerts)
  lat          Float?
  lng          Float?
  locationName String?

  stormAlerts  Boolean   @default(true)
  lastNotifiedAt DateTime?
  failureCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([stormAlerts])
  @@map("push_subscriptions")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model UserPreferences {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferredUnit   String  @default("imperial")
  sport           String  @default("cycling")
  ebikeMode       Boolean @default(false)
  preferCold      Boolean @default(false)
  dislikeWind     Boolean @default(false)
  temperatureMin  Float?
  temperatureMax  Float?

  @@map("user_preferences")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier                 String    @default("free")
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("active")
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("subscriptions")
}

model Route {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  name          String
  sport         String    @default("cycling")
  distance      Float
  elevationGain Float
  geometry      String                       // JSON string (GeoJSON LineString)
  bearings      String    @default("[]")   // JSON string array of bearings
  segments      String                     // JSON string of segmented route data
  isPublic      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rideScoreHistory RideScoreHistory[]

  @@index([sport])
  @@map("routes")
}

model WeatherSnapshot {
  id            String    @id @default(cuid())
  lat           Float
  lng           Float
  timestamp     DateTime

  tempF         Float
  feelsLikeF    Float
  humidity      Int
  windSpeedMph  Float
  windGustMph   Float?
  windDirDeg    Int
  precipProb    Float
  precipInch    Float     @default(0)
  cloudCover    Int
  visibility    Float
  uvIndex       Float?
  condition     String
  conditionCode Int
  isStorm       Boolean   @default(false)
  isIce         Boolean   @default(false)

  provider      String    @default("openweathermap")
  createdAt     DateTime  @default(now())

  @@index([lat, lng, timestamp])
  @@map("weather_snapshots")
}

model RideScoreHistory {
  id         String    @id @default(cuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  routeId    String?
  route      Route?    @relation(fields: [routeId], references: [id], onDelete: SetNull)

  sport      String    @default("cycling")
  score      Float
  label      String
  breakdown  String    // JSON string of per-factor scores
  weatherId  String?
  lat        Float
  lng        Float
  timestamp  DateTime
  createdAt  DateTime  @default(now())

  @@index([userId, timestamp])
  @@index([routeId, timestamp])
  @@map("ride_score_history")
}

model DeviceIntegration {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scopes       String    @default("[]")   // JSON array of scopes (String[]) — SQLite compat
  metadata     String?   // JSON string

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
  @@map("device_integrations")
}

// Short-lived records for the device-pairing ("show a QR, approve on phone")
// login flow used by the Garmin / Wear OS apps.
model DevicePairing {
  id           String    @id @default(cuid())
  code         String    @unique              // user-facing code, embedded in the QR URL
  deviceSecret String    @unique              // opaque secret the device polls with
  status       String    @default("pending")  // pending | approved | consumed
  token        String?                        // issued JWT, set on approval
  userId       String?                        // who approved it
  deviceLabel  String?                        // optional label (e.g. "edge540")
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([deviceSecret])
  @@map("device_pairings")
}

// A live, shareable activity feed. The token goes in a public /watch/<token>
// link so family/friends can follow along without an account. Ends when the
// rider stops; positions are appended as the ride progresses.
model LiveSession {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  sport       String    @default("cycling")
  status      String    @default("active")   // active | ended
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  lat         Float?
  lng         Float?
  speedMph    Float?
  headingDeg  Float?
  distanceMi  Float     @default(0)
  elapsedSec  Int       @default(0)
  path        String    @default("[]")        // JSON array of [lng, lat] breadcrumbs (capped)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@map("live_sessions")
}

// People to alert in an emergency (e.g. a spouse). The SOS button emails these
// contacts the rider's live location / watch link.
model EmergencyContact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  relation  String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("emergency_contacts")
}

// Rider-reported road problems — closures, hazards, construction, flooding,
// etc. Shown to nearby riders on the live map. Auto-expire so stale reports
// don't linger.
model RoadClosure {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  lat         Float
  lng         Float
  type        String   @default("closure")   // closure | hazard | construction | flooding | crash | other
  description String?
  severity    String   @default("warning")   // info | warning | danger
  status      String   @default("active")     // active | cleared
  confirmations Int    @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lat, lng])
  @@index([status, expiresAt])
  @@map("road_closures")
}

// Completed rides — synced from the client so the user's history shows on
// every device they log into (phone + PC). Client generates the id, so re-syncs
// are idempotent. The heavy GPS track lives in `points` (JSON); the list
// endpoint omits it to keep responses small.
model Ride {
  id            String   @id                      // client-generated, e.g. "ride_<startedAtMs>"
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  startedAt     DateTime
  endedAt       DateTime
  sport         String   @default("cycling")

  totalDistMi   Float
  movingTimeSec Int
  totalTimeSec  Int
  avgSpeedMph   Float
  maxSpeedMph   Float
  ascentFt      Float
  descentFt     Float
  avgHrBpm      Int?
  maxHrBpm      Int?
  notes         String?

  points        String   @default("[]")   // JSON TrackPoint[]
  laps          String   @default("[]")   // JSON laps
  stops         String   @default("[]")   // JSON stops

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, startedAt])
  @@map("rides")
}

model PartnerListing {
  id          String    @id @default(cuid())
  name        String
  type        String
  lat         Float
  lng         Float
  address     String
  phone       String?
  website     String?
  description String?
  isVerified  Boolean   @default(false)
  tier        String    @default("free")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([lat, lng])
  @@index([type])
  @@map("partner_listings")
}
