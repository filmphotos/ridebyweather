<?xml version="1.0"?>
<!-- Connect IQ app for RideByWeather: shows the ride/heat-risk score on
     Garmin Edge bike computers and watches. Add/remove devices in the
     <iq:products> list (the VS Code Monkey C extension has a product picker). -->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application
        id="c22a9990d1a5446491a4d9e5759b65dd"
        type="watch-app"
        name="@Strings.AppName"
        entry="RbwApp"
        launcherIcon="@Drawables.LauncherIcon"
        minApiLevel="3.1.0">

        <iq:products>
            <!-- Edge bike computers -->
            <iq:product id="edge530"/>
            <iq:product id="edge830"/>
            <iq:product id="edge1030plus"/>
            <iq:product id="edge540"/>
            <iq:product id="edge840"/>
            <iq:product id="edge1040"/>
            <!-- Watches -->
            <iq:product id="fenix7"/>
            <iq:product id="fenix7x"/>
            <iq:product id="fr955"/>
            <iq:product id="fr265"/>
            <iq:product id="venu2"/>
            <iq:product id="venu3"/>
            <iq:product id="vivoactive4"/>
            <iq:product id="epix2"/>
        </iq:products>

        <iq:permissions>
            <iq:uses-permission id="Communications"/>
            <iq:uses-permission id="Positioning"/>
        </iq:permissions>

        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
