{
  "name": "ridebyweather",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/prisma-schema-local.mjs && prisma generate --schema=prisma/schema.local.prisma",
    "dev": "next dev",
    "build": "prisma generate && prisma db push --skip-generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:generate:local": "node scripts/prisma-schema-local.mjs && prisma generate --schema=prisma/schema.local.prisma",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "android:sync": "cap sync android",
    "android:open": "cap open android",
    "android:run": "cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@prisma/client": "^5.22.0",
    "@stripe/stripe-js": "^4.9.0",
    "@vis.gl/react-mapbox": "8.1.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "mapbox-gl": "3.8.0",
    "next": "^15.5.18",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "8.1.1",
    "recharts": "^2.13.3",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.5.5",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/ms": "^2.1.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^8",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
