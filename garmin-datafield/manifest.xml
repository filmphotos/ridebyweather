<?xml version="1.0"?>
<!-- RideByWeather Connect IQ DATA FIELD: shows the ride/heat-risk score inside
     the rider's normal Garmin activity data screen. Separate app from the
     full RideByWeather device app (Connect IQ keeps their storage separate),
     so it pairs independently. -->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application
        id="c5b7325e04d1470c9890cd5abc056936"
        type="datafield"
        name="@Strings.AppName"
        entry="RbwDataFieldApp"
        launcherIcon="@Drawables.LauncherIcon"
        minApiLevel="3.1.0">

        <iq:products>
            <iq:product id="edge530"/>
            <iq:product id="edge830"/>
            <iq:product id="edge1030plus"/>
            <iq:product id="edge540"/>
            <iq:product id="edge840"/>
            <iq:product id="edge1040"/>
            <iq:product id="fenix7"/>
            <iq:product id="fr955"/>
        </iq:products>

        <iq:permissions>
            <iq:uses-permission id="Communications"/>
            <iq:uses-permission id="Positioning"/>
        </iq:permissions>

        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
